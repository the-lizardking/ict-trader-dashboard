# Leave VITE_BOT_API_URL empty in production so the dashboard fetches
# /api/bot/* same-origin and Vercel's rewrite (vercel.json) proxies
# the request to the bot VPS. This avoids the browser's mixed-content
# block (HTTPS dashboard -> HTTP bot) and makes CORS irrelevant.
#
# Override only when you want to bypass the rewrite, e.g. local dev
# ("http://localhost:8001") or a TLS-terminated bot endpoint.
VITE_BOT_API_URL=
GEMINI_API_KEY=your_gemini_api_key
